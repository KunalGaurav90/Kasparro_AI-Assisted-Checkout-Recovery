}

/* TRIGGER 1 — score 4-6: in-page nudges */
function fireTrigger1(){
  if(trigger1Fired)return; trigger1Fired=true
  setTimeout(()=>document.getElementById('spBar').classList.add('show'),300)
  setTimeout(()=>{ var u=document.getElementById('urgencyBadge'); u.style.display='inline-flex' },800)
