function triggerRecovery(){
  if(triggered)return; triggered=true
  frictionType=classifyFriction()
  var qrMap={
    price_hesitation:['Discount code?','Return policy?','Price feels high'],
    shipping_confusion:['When does it arrive?','Free shipping?','Express option?'],
    trust_gap:['Is payment safe?','Return policy?','Contact support'],
    payment_hesitation:['Which cards work?','Try UPI instead?','Return policy?'],
    general:['Discount code?','Return policy?','Shipping cost?','Pay in EMI?']
  }
  document.getElementById('rwQR').innerHTML=(qrMap[frictionType]||qrMap.general).map(q=>'<button class="rwqrbtn" onclick="sendQR(this)">'+q+'</button>').join('')
  document.getElementById('rw').classList.add('show')
  var openings={
    price_hesitation:'Looks like you\'re deciding — we offer free returns within 30 days on every order. Would that help you feel more confident completing the purchase?',
    shipping_confusion:'Quick note on shipping — standard delivery arrives in 4–6 days, and orders above ₹3,000 qualify for free shipping. Does the timeline work for you?',
    trust_gap:'Your payment is protected by 256-bit SSL and we never store card details. Is there anything about the order I can help clarify?',
    payment_hesitation:'We accept all major cards, UPI, and net banking — all secured with 256-bit SSL. Having trouble with a payment method?',
    general:'Hi! Noticed you\'ve been here a while — can I help with anything about your order?'
  }
  var msg=openings[frictionType]||openings.general
  appendMsg('ai',msg)
  convHistory.push({role:'user',content:'[System: Friction='+frictionType+', Cart=₹'+cartTotal+', Shipping=₹'+shippingCost+']'})
  convHistory.push({role:'assistant',content:msg})
  setTimeout(showFeatureCards,1800)
  // Trigger 3 — push prompt after 10s
  setTimeout(()=>{if(!document.getElementById('placeBtn').textContent.includes('✓'))document.getElementById('pushPrompt').classList.add('show')},10000)
}

