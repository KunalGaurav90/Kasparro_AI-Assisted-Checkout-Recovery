      '<div class="feat-card-btn">Apply now — one click</div></div>'+
    '<div class="feat-card upgrade" onclick="upgradeShipping()">'+
      '<div class="feat-card-title">⚡ Upgrade to Express?</div>'+
      '<div>Add just ₹200 more for delivery in 1–2 days instead of 4–6</div>'+
      '<div style="font-size:11px;opacity:.7;margin-top:4px">Tap to switch →</div></div>'+
    '<div class="feat-card save" onclick="saveForLater()">'+
      '<div class="feat-card-title">💌 Save cart for later</div>'+
      '<div>We\'ll email you a link to resume this exact order anytime</div>'+
