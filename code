/* CLAUDE API */
async function callClaude(userMsg){
  var sys='You are a helpful checkout assistant for Marketo. Resolve the buyer concern and help complete their purchase.\nRules: ONE question per reply. Max 60 words. Never invent policies.\nFacts: Returns=30 days free | Free shipping above ₹3000 | SSL 256-bit | Coupon SAVE10=10% off | EMI 3 months 0%\nCart: ₹'+cartTotal+' | Shipping: ₹'+shippingCost+' ('+shippingLabel+') | Friction: '+frictionType
  try{
    var msgs=convHistory.filter(m=>m.role==='user'||m.role==='assistant').slice(-8)
    var res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json','x-api-key':ANTHROPIC_KEY,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:200,system:sys,messages:msgs})})
    if(!res.ok)throw new Error(res.status)
    var data=await res.json(),reply=data.content[0].text
    removeTyping(); appendMsg('ai',reply); convHistory.push({role:'assistant',content:reply})
  }catch(e){removeTyping();var fb=localReply(userMsg);appendMsg('ai',fb);convHistory.push({role:'assistant',content:fb});console.warn('Claude fallback:',e.message)}
}

/* FALLBACKS */
function localReply(t){
  t=t.toLowerCase()
  if(t.includes('discount')||t.includes('coupon')||t.includes('offer'))return'Use code SAVE10 for 10% off — just enter it in the coupon box on the right!'
  if(t.includes('return')||t.includes('refund')||t.includes('exchange'))return'Free returns within 30 days, no questions asked. We arrange a free pickup from your door.'
  if(t.includes('shipping')||t.includes('delivery')||t.includes('free'))return'Standard shipping is ₹199 for 4–6 days. Orders above ₹3,000 get free shipping — you\'re ₹'+Math.max(0,3000-cartTotal)+' away!'
  if(t.includes('emi')||t.includes('instalment')||t.includes('monthly'))return'Pay in 3 instalments of ₹'+Math.round(cartTotal/3).toLocaleString('en-IN')+'/month at 0% interest via HDFC or ICICI EMI.'
  if(t.includes('size')||t.includes('fit'))return'Shoes run true to UK sizing. Free exchanges within 30 days if the fit isn\'t right — no hassle.'
  if(t.includes('safe')||t.includes('secure')||t.includes('trust'))return'Completely safe — 256-bit SSL, PCI-DSS certified. We never store card details.'
  if(t.includes('when')||t.includes('arrive')||t.includes('days'))return'Standard arrives in 4–6 business days. Express (₹399) delivers in 1–2 business days.'
  return'Happy to help! Our 24/7 support team is always available too. Is there something specific I can clarify?'
}
