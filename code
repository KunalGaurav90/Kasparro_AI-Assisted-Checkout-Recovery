<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Marketo — Checkout</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --font:'DM Sans',-apple-system,sans-serif;--mono:'DM Mono',monospace;
  --bg:#f4f3ef;--surface:#fff;--surface2:#f9f8f5;
  --border:#e5e4de;--border2:#d0cfc8;
  --t1:#18181a;--t2:#6b6a65;--t3:#a3a29d;
  --green:#1a9e6a;--green-bg:#e8f7f0;--green-t:#0d6644;
  --red-bg:#fdf0f0;--red-t:#9b2424;
  --amber:#f59e0b;--amber-bg:#fff8e6;--amber-t:#8a6000;
  --blue:#3b82f6;--blue-bg:#eff6ff;--blue-t:#1d4ed8;
  --purple:#8b5cf6;--purple-bg:#f5f3ff;--purple-t:#6d28d9;
  --r-sm:6px;--r-md:10px;--r-lg:14px;
  --sh:0 1px 3px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.04);
  --sh-md:0 4px 16px rgba(0,0,0,.1);
}
html{scroll-behavior:smooth}
body{font-family:var(--font);background:var(--bg);color:var(--t1);font-size:14px;line-height:1.6;-webkit-font-smoothing:antialiased}
input,select,button,textarea{font-family:inherit;font-size:inherit}
button{cursor:pointer;border:none;background:none}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-thumb{background:var(--border2);border-radius:99px}

/* NAV */
.nav{background:#fff;border-bottom:1px solid var(--border);padding:0 28px;height:54px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:200;box-shadow:var(--sh)}
.logo{font-size:18px;font-weight:600;letter-spacing:-.4px}
.nav-steps{display:flex;align-items:center;gap:3px}
.sep{color:var(--border2);padding:0 3px;font-size:12px}
.stp{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--t3);padding:0 5px}
.stp.done{color:var(--green)}.stp.act{color:var(--t1);font-weight:500}
.snum{width:20px;height:20px;border-radius:50%;background:var(--border);font-size:10px;font-weight:600;display:flex;align-items:center;justify-content:center;color:var(--t2)}
.stp.act .snum{background:var(--t1);color:#fff}.stp.done .snum{background:var(--green);color:#fff}
.nav-secure{font-size:11px;color:var(--t3)}

/* API BANNER */
.api-banner{background:var(--amber-bg);border:1px solid #f0d080;border-radius:var(--r-md);padding:10px 16px;margin:12px auto;max-width:960px;display:flex;gap:10px;align-items:center;flex-wrap:wrap}
.api-banner label{font-size:12px;font-weight:500;color:#6b5000;white-space:nowrap}
.api-banner input{flex:1;min-width:240px;border:1.5px solid #e0c070;border-radius:var(--r-sm);padding:6px 10px;font-size:12px;font-family:var(--mono);background:#fffdf0;outline:none}
.api-banner input:focus{border-color:#c09000}
.save-btn{padding:6px 13px;background:var(--t1);color:#fff;border-radius:var(--r-sm);font-size:12px;font-weight:500;cursor:pointer}
.api-status{font-size:11px;color:var(--green);font-weight:500;display:none}

/* MAIN */
.main{display:grid;grid-template-columns:1fr 370px;gap:36px;max-width:960px;margin:0 auto;padding:20px 24px 64px}
.stitle{font-size:10px;font-weight:600;color:var(--t3);letter-spacing:.08em;text-transform:uppercase;margin-bottom:10px}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:18px;margin-bottom:18px;box-shadow:var(--sh)}

/* SOCIAL PROOF BAR */
.sp-bar{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-md);padding:8px 14px;margin-bottom:10px;display:flex;align-items:center;gap:10px;opacity:0;transform:translateY(-6px);transition:all .4s ease}
.sp-bar.show{opacity:1;transform:translateY(0)}
.sp-dot{width:8px;height:8px;border-radius:50%;background:var(--green);flex-shrink:0;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(26,158,106,.4)}50%{box-shadow:0 0 0 6px rgba(26,158,106,0)}}
.sp-text{font-size:12px;color:var(--t2);flex:1}.sp-text strong{color:var(--t1)}
.sp-close{font-size:11px;color:var(--t3);cursor:pointer;padding:2px 5px}

/* URGENCY */
.urgency-badge{display:none;align-items:center;gap:5px;background:var(--red-bg);border:1px solid #f5c0c0;color:var(--red-t);font-size:11px;font-weight:500;padding:5px 10px;border-radius:5px;margin-bottom:10px}

/* SHIPPING */
.sopt{display:flex;align-items:center;gap:12px;padding:11px 13px;border:1.5px solid var(--border);border-radius:var(--r-md);margin-bottom:8px;cursor:pointer;transition:all .15s}
.sopt:last-child{margin-bottom:0}.sopt:hover:not(.sel){border-color:var(--border2);background:var(--surface2)}.sopt.sel{border-color:var(--t1);background:var(--surface2)}
.sopt input[type=radio]{accent-color:var(--t1);width:15px;height:15px;flex-shrink:0}
.slbl{flex:1;font-size:13px;font-weight:500;color:var(--t1)}.seta{font-size:11px;font-weight:400;color:var(--t3);margin-top:2px}
.sprc{font-size:13px;font-weight:600;color:var(--t1)}
.bfree{font-size:9px;font-weight:600;background:var(--green-bg);color:var(--green-t);padding:2px 6px;border-radius:3px;margin-left:6px}

/* PAYMENT */
.ptabs{display:flex;gap:8px;margin-bottom:14px}
.ptab{flex:1;padding:9px 6px;border:1.5px solid var(--border);border-radius:var(--r-sm);font-size:12px;font-weight:500;color:var(--t3);cursor:pointer;background:var(--surface2);text-align:center;transition:all .15s}
.ptab:hover{border-color:var(--border2);color:var(--t2)}.ptab.on{border-color:var(--t1);color:var(--t1);background:#fff}
.pform{display:none}.pform.on{display:flex;flex-wrap:wrap;gap:10px}
.fld{display:flex;flex-direction:column;gap:5px}.fld.full{width:100%}.fld.half{flex:1;min-width:110px}
.fld label{font-size:10px;font-weight:600;color:var(--t3);letter-spacing:.05em;text-transform:uppercase}
.fld input,.fld select{border:1.5px solid var(--border);border-radius:var(--r-sm);padding:9px 11px;font-size:13px;color:var(--t1);background:var(--surface2);outline:none;transition:all .15s;width:100%}
.fld input:focus,.fld select:focus{border-color:var(--t1);background:#fff;box-shadow:0 0 0 3px rgba(24,24,26,.05)}
.fld input::placeholder{color:var(--t3)}.upi-note{font-size:11px;color:var(--t3);width:100%;margin-top:2px}
.trust{display:flex;gap:14px;margin-top:14px;padding-top:14px;border-top:1px solid var(--border);flex-wrap:wrap}
.trust span{font-size:11px;color:var(--t3)}
.pbtn{width:100%;padding:14px;background:var(--t1);color:#fff;border:none;border-radius:var(--r-md);font-size:15px;font-weight:500;cursor:pointer;transition:background .15s}
.pbtn:hover{background:#333}.pnote{font-size:11px;color:var(--t3);text-align:center;margin-top:9px}

/* ORDER SUMMARY */
.clist{border:1px solid var(--border);border-radius:var(--r-lg);background:var(--surface);overflow:hidden;margin-bottom:13px;box-shadow:var(--sh)}
.ci{display:flex;align-items:center;gap:11px;padding:13px 15px;border-bottom:1px solid var(--border)}.ci:last-child{border-bottom:none}
.cimg{width:48px;height:48px;border-radius:var(--r-sm);background:var(--surface2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0}
.cnm{font-size:13px;font-weight:500;line-height:1.3}.cmt{font-size:11px;color:var(--t3);margin-top:2px}.cqt{font-size:11px;color:var(--t3);margin-top:2px}.cpr{font-size:13px;font-weight:600;white-space:nowrap}
.cpnrow{display:flex;gap:8px;margin-bottom:7px}
.cpnrow input{flex:1;border:1.5px solid var(--border);border-radius:var(--r-sm);padding:8px 11px;font-size:13px;outline:none;background:var(--surface2);color:var(--t1);transition:border .15s}
.cpnrow input:focus{border-color:var(--t1);background:#fff}.cpnrow input::placeholder{color:var(--t3)}
.cpnbtn{padding:8px 14px;background:var(--surface2);border:1.5px solid var(--border);border-radius:var(--r-sm);font-size:12px;font-weight:500;cursor:pointer;color:var(--t2);white-space:nowrap;transition:all .15s}
.cpnbtn:hover{background:var(--t1);color:#fff;border-color:var(--t1)}
.cpnmsg{font-size:12px;padding:6px 10px;border-radius:var(--r-sm);margin-bottom:8px;display:none}
.cpnmsg.ok{background:var(--green-bg);color:var(--green-t)}.cpnmsg.err{background:var(--red-bg);color:var(--red-t)}
.sumrow{display:flex;justify-content:space-between;font-size:13px;color:var(--t2);padding:5px 0}
.sumrow.muted{font-size:11px;color:var(--t3)}.sumrow.tot{font-size:15px;font-weight:600;color:var(--t1);border-top:1px solid var(--border);margin-top:6px;padding-top:11px}
.gbox{display:flex;gap:10px;align-items:flex-start;background:var(--surface2);border:1px solid var(--border);border-radius:var(--r-md);padding:11px 13px;margin-top:8px}
.gbox strong{font-size:13px;font-weight:500}.gbox p{font-size:11px;color:var(--t3);margin-top:2px}

/* TOAST */
.toast-container{position:fixed;bottom:80px;left:24px;z-index:9998;display:flex;flex-direction:column;gap:8px;pointer-events:none}
.toast{background:#18181a;color:#fff;padding:11px 15px;border-radius:10px;font-size:13px;box-shadow:var(--sh-md);display:flex;align-items:center;gap:10px;transform:translateX(-120%);opacity:0;transition:all .4s cubic-bezier(.34,1.56,.64,1);pointer-events:all;max-width:280px}
.toast.show{transform:translateX(0);opacity:1}
.toast-icon{font-size:16px;flex-shrink:0}.toast-body{flex:1}
.toast-title{font-weight:500;font-size:12px;line-height:1.3}.toast-sub{font-size:11px;color:#ffffff80;margin-top:1px}
.toast-close{font-size:12px;color:#ffffff60;cursor:pointer;padding:0 2px;flex-shrink:0}.toast-close:hover{color:#fff}
.toast.green{background:var(--green)}.toast.amber{background:#d97706}.toast.blue{background:#2563eb}

/* RECOVERY WIDGET */
.rw{position:fixed;bottom:24px;right:24px;width:350px;background:#fff;border:1px solid var(--border);border-radius:16px;box-shadow:0 8px 32px rgba(0,0,0,.14),0 2px 8px rgba(0,0,0,.06);display:flex;flex-direction:column;overflow:hidden;transform:translateY(24px);opacity:0;pointer-events:none;transition:transform .32s cubic-bezier(.34,1.56,.64,1),opacity .25s ease;z-index:9999}
.rw.show{transform:translateY(0);opacity:1;pointer-events:all}
.rwh{display:flex;align-items:center;justify-content:space-between;padding:11px 14px;background:#18181a;flex-shrink:0}
.rwhl{display:flex;align-items:center;gap:9px}
.rwav{width:32px;height:32px;border-radius:50%;background:#ffffff20;border:1.5px solid #ffffff30;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;color:#fff;flex-shrink:0}
.rwnm{font-size:13px;font-weight:500;color:#fff;line-height:1.2}
.rwst{display:flex;align-items:center;gap:5px;font-size:11px;color:#ffffff70;margin-top:1px}
.rwdot{width:6px;height:6px;border-radius:50%;background:#4ade80;flex-shrink:0}
.rwhbts{display:flex;gap:3px}
.rwhbt{width:27px;height:27px;border-radius:5px;color:#ffffff60;font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s}
.rwhbt:hover{background:#ffffff15;color:#fff}
.rwmsgs{padding:12px 12px 6px;display:flex;flex-direction:column;gap:9px;max-height:280px;overflow-y:auto;background:#fafaf8;flex:1}
.rwmsgs::-webkit-scrollbar{width:3px}.rwmsgs::-webkit-scrollbar-thumb{background:var(--border);border-radius:99px}
.rwmsg{display:flex;align-items:flex-end;gap:6px}.rwmsg.user{flex-direction:row-reverse}
.rwmav2{width:22px;height:22px;border-radius:50%;background:#18181a;color:#fff;font-size:10px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.rwbbl{max-width:84%;padding:8px 11px;border-radius:11px;font-size:13px;line-height:1.55;word-break:break-word}
.rwmsg.ai .rwbbl{background:#fff;border:1px solid var(--border);border-bottom-left-radius:3px;color:var(--t1)}
.rwmsg.user .rwbbl{background:#18181a;color:#fff;border-bottom-right-radius:3px}
.rwtyp{display:flex;align-items:center;gap:4px;padding:10px 11px}
.rwtyp span{width:6px;height:6px;border-radius:50%;background:#c0bfba;animation:rwb 1.2s infinite ease-in-out}
.rwtyp span:nth-child(2){animation-delay:.2s}.rwtyp span:nth-child(3){animation-delay:.4s}
@keyframes rwb{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-5px)}}

/* FEATURE CARDS inside chat */
.feat-cards{display:flex;flex-direction:column;gap:7px;margin:4px 0 4px 28px}
.feat-card{border-radius:10px;padding:10px 12px;font-size:12px;line-height:1.5;cursor:pointer;transition:all .15s;border:1.5px solid transparent}
.feat-card.discount{background:var(--green-bg);border-color:#b6e8d2;color:#0d4a2f}.feat-card.discount:hover{background:#d0f0e4}
.feat-card.upgrade{background:var(--blue-bg);border-color:#bfdbfe;color:#1e3a8a}.feat-card.upgrade:hover{background:#dbeafe}
.feat-card.save{background:var(--purple-bg);border-color:#ddd6fe;color:#4c1d95}.feat-card.save:hover{background:#ede9fe}
.feat-card.emi{background:var(--amber-bg);border-color:#fde68a;color:#78350f}.feat-card.emi:hover{background:#fef3c7}
.feat-card-title{font-weight:600;margin-bottom:2px}
.feat-card-btn{display:inline-block;margin-top:6px;padding:4px 10px;border-radius:5px;font-size:11px;font-weight:500;background:#18181a;color:#fff;cursor:pointer}

.rwqr{display:flex;flex-wrap:wrap;gap:5px;padding:7px 12px;background:#fafaf8;border-top:1px solid #f0f0ea}
.rwqrbtn{font-size:11px;font-weight:500;padding:4px 10px;border:1px solid #e0dfd8;border-radius:99px;background:#fff;color:#444;cursor:pointer;white-space:nowrap;transition:all .15s}
.rwqrbtn:hover{background:#18181a;color:#fff;border-color:#18181a}
.rwinrow{display:flex;align-items:center;gap:7px;padding:10px 11px;border-top:1px solid var(--border);background:#fff;flex-shrink:0}
.rwinin{flex:1;border:1.5px solid var(--border);border-radius:7px;padding:7px 11px;font-size:13px;outline:none;background:var(--surface2);color:var(--t1);transition:border .15s}
.rwinin:focus{border-color:var(--t1);background:#fff}.rwinin::placeholder{color:var(--t3)}
.rwsnd{width:33px;height:33px;border-radius:7px;border:none;font-size:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .15s;cursor:pointer}
.rwsnd.on{background:#18181a;color:#fff}.rwsnd.off{background:#e5e4de;color:#a3a29d;cursor:not-allowed}

/* PUSH PROMPT */
.push-prompt{position:fixed;top:70px;right:24px;width:300px;background:#fff;border:1px solid var(--border);border-radius:12px;padding:14px 16px;box-shadow:var(--sh-md);z-index:9997;transform:translateX(120%);opacity:0;transition:all .4s cubic-bezier(.34,1.56,.64,1)}
.push-prompt.show{transform:translateX(0);opacity:1}
.pp-title{font-size:13px;font-weight:500;margin-bottom:4px}.pp-sub{font-size:12px;color:var(--t2);margin-bottom:10px}
.pp-btns{display:flex;gap:7px}
.pp-allow{flex:1;padding:7px;background:#18181a;color:#fff;border-radius:6px;font-size:12px;font-weight:500;cursor:pointer}
.pp-deny{flex:1;padding:7px;background:var(--surface2);border:1px solid var(--border);border-radius:6px;font-size:12px;color:var(--t2);cursor:pointer}

/* ADMIN PANEL */
.admin-toggle{position:fixed;top:70px;left:24px;background:#18181a;color:#fff;font-size:11px;font-weight:500;padding:6px 12px;border-radius:6px;cursor:pointer;z-index:9996;box-shadow:var(--sh-md)}
.admin-panel{position:fixed;top:0;left:0;height:100vh;width:360px;background:#fff;border-right:1px solid var(--border);z-index:10000;transform:translateX(-100%);transition:transform .3s ease;box-shadow:4px 0 24px rgba(0,0,0,.1);display:flex;flex-direction:column;overflow:hidden}
.admin-panel.open{transform:translateX(0)}
.ap-header{background:#18181a;color:#fff;padding:16px 18px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.ap-title{font-size:15px;font-weight:600}
.ap-close{font-size:14px;color:#ffffff60;cursor:pointer;padding:4px 7px;border-radius:5px}.ap-close:hover{background:#ffffff15;color:#fff}
.ap-body{flex:1;overflow-y:auto;padding:16px}
.ap-section{margin-bottom:20px}
.ap-stitle{font-size:10px;font-weight:600;color:var(--t3);letter-spacing:.08em;text-transform:uppercase;margin-bottom:9px}
.ap-stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.ap-stat{background:var(--surface2);border:1px solid var(--border);border-radius:var(--r-md);padding:10px 12px}
.ap-stat-val{font-size:20px;font-weight:600;color:var(--t1);line-height:1}
.ap-stat-label{font-size:11px;color:var(--t3);margin-top:3px}
.ap-stat.green .ap-stat-val{color:var(--green)}.ap-stat.amber .ap-stat-val{color:var(--amber)}
.ap-chart{background:var(--surface2);border:1px solid var(--border);border-radius:var(--r-md);padding:12px;margin-top:6px}
.ap-chart-title{font-size:11px;color:var(--t2);font-weight:500;margin-bottom:10px}
.chart-bars{display:flex;align-items:flex-end;gap:6px;height:60px;margin-bottom:18px}
.chart-bar{flex:1;border-radius:3px 3px 0 0;position:relative}
.chart-bar span{position:absolute;bottom:-16px;left:50%;transform:translateX(-50%);font-size:9px;color:var(--t3);white-space:nowrap}
.ap-session-row{display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(--border)}.ap-session-row:last-child{border-bottom:none}
.ap-s-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.ap-s-dot.live{background:var(--green);animation:pulse 2s infinite}.ap-s-dot.done{background:var(--blue)}.ap-s-dot.lost{background:var(--red-t)}
.ap-s-info{flex:1;font-size:12px}.ap-s-name{font-weight:500;color:var(--t1)}.ap-s-meta{color:var(--t3);font-size:11px;margin-top:1px}
.ap-s-tag{font-size:10px;font-weight:500;padding:2px 7px;border-radius:4px}
.ap-s-tag.converted{background:var(--green-bg);color:var(--green-t)}.ap-s-tag.live{background:var(--blue-bg);color:var(--blue-t)}.ap-s-tag.lost{background:var(--red-bg);color:var(--red-t)}
.ap-alert{border-radius:var(--r-md);padding:10px 12px;margin-bottom:8px;font-size:12px;background:var(--amber-bg);border:1px solid #f0d080}
.ap-alert-title{font-weight:500;color:var(--amber-t)}.ap-alert-body{color:#6b5000;margin-top:2px;font-size:11px}
.ap-alert.ok{background:var(--green-bg);border-color:#b6e8d2}.ap-alert.ok .ap-alert-title{color:var(--green-t)}.ap-alert.ok .ap-alert-body{color:#0d4a2f}
.ap-notif-row{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:12px}.ap-notif-row:last-child{border-bottom:none}
.toggle{width:36px;height:20px;border-radius:10px;background:var(--border);position:relative;cursor:pointer;transition:background .2s;flex-shrink:0}
.toggle.on{background:var(--green)}
.toggle::after{content:'';position:absolute;width:14px;height:14px;border-radius:50%;background:#fff;top:3px;left:3px;transition:left .2s;box-shadow:0 1px 3px rgba(0,0,0,.2)}
.toggle.on::after{left:19px}

/* DEBUG */
.dbg{position:fixed;bottom:24px;left:24px;background:#18181a;color:#fff;font-family:var(--mono);font-size:11px;padding:8px 12px;border-radius:8px;z-index:300;line-height:1.8;opacity:.9}

@media(max-width:700px){
  .main{grid-template-columns:1fr;padding:14px 12px 80px}.right{order:-1}
  .nav-secure{display:none}.rw{width:100%;bottom:0;right:0;border-radius:16px 16px 0 0}
  .admin-panel{width:100%}
}
</style>
</head>
<body>

<!-- ADMIN TOGGLE -->
<button class="admin-toggle" onclick="toggleAdmin()">📊 Admin Dashboard</button>

<!-- ADMIN PANEL -->
<div class="admin-panel" id="adminPanel">
  <div class="ap-header">
    <div class="ap-title">📊 Merchant Dashboard</div>
    <button class="ap-close" onclick="toggleAdmin()">✕ Close</button>
  </div>
  <div class="ap-body">
    <div class="ap-section">
      <div class="ap-stitle">Today's recovery stats</div>
      <div class="ap-stat-grid">
