}

/* SCORE */
function addSignal(name,pts){
  if(triggered)return
  if(signals.find(s=>s.n===name))return
  score+=pts; signals.push({n:name,pts})
  document.getElementById('scoreVal').textContent=score
  document.getElementById('signalList').textContent=signals.map(s=>s.n).join(', ')
  document.getElementById('dbgScoreAdmin').textContent=score
  document.getElementById('dbgFrictionAdmin').textContent=signals.map(s=>s.n).join(', ')||'none'
  if(score>=4&&!trigger1Fired)fireTrigger1()
  if(score>=THRESHOLD)triggerRecovery()
}

function classifyFriction(){
  var n=signals.map(s=>s.n)
  if(n.includes('shipping_confusion'))return'shipping_confusion'
  if(n.includes('tab_blur')||n.includes('back_button_hover'))return'trust_gap'
  if(n.includes('payment_field_abandoned'))return'payment_hesitation'
  if(n.includes('price_scroll_back'))return'price_hesitation'
  return'general'
}

