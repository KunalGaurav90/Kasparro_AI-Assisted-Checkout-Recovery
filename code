function esc(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}

function sendMsg(){
  var inp=document.getElementById('rwInput'),txt=inp.value.trim(); if(!txt)return
  document.getElementById('rwQR').style.display='none'
  appendMsg('user',txt); convHistory.push({role:'user',content:txt})
